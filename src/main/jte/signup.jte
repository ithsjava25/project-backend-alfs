<h1>Sign up</h1>

<form method="post" action="/signup-form">
    <div>
        <label>Username</label>
        <input name="username" />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" />
    </div>

    <button type="submit">Create account</button>
</form>

<a href="/login">Already have an account? Login</a>